{
  "name": "${containerEnv:PROJECT_NAME:Flutter Development}",
  "_devcontainer_version": "1.4.0",
  "_template_version": "flutter-devcontainer-1.4.0",
  "dockerComposeFile": ["docker-compose.yml", "docker-compose.override.yml"],
  "service": "app",
  "workspaceFolder": "/workspace",
  "initializeCommand": "rm -rf /tmp/vscode-extensions-* || true",

  "forwardPorts": [8080, 9100, 1455],

  "portsAttributes": {
    "8080": {
      "label": "Flutter Hot Reload",
      "onAutoForward": "notify"
    },
    "9100": {
      "label": "Flutter DevTools",
      "onAutoForward": "notify"
    },
    "1455": {
      "label": "Codex auth callback",
      "onAutoForward": "silent"
    }
  },

  "shutdownAction": "stopCompose",

  "mounts": [
    // Make local AI CLI configs available inside the container
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=${localEnv:HOME}/.claude,type=bind",
    "source=${localEnv:HOME}/.codex,target=${localEnv:HOME}/.codex,type=bind"
  ],

  "remoteUser": "${localEnv:USER}",
  "updateRemoteUserUID": false,

  "containerEnv": {
    "SHELL": "/bin/zsh",
    "TERM_PROGRAM": "${localEnv:TERM_PROGRAM}",
    "WARP_HONOR_PS1": "1",
    "WARP_USE_SSH_WRAPPER": "${localEnv:WARP_USE_SSH_WRAPPER}",
    "WARP_IS_LOCAL_SHELL_SESSION": "${localEnv:WARP_IS_LOCAL_SHELL_SESSION}",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },

  "postCreateCommand": {
    "env": "cp -n .devcontainer/.env.base .devcontainer/.env || true",
    "cleanup": "rm -rf /home/${localEnv:USER}/.vscode-server/extensions/.* 2>/dev/null || true",
    "fix-claude-logo": "mkdir -p /home/${localEnv:USER}/.vscode-server/extensions/anthropic.claude-code-*/resources/ 2>/dev/null && cp .devcontainer/assets/claude-logo.svg /home/${localEnv:USER}/.vscode-server/extensions/anthropic.claude-code-*/resources/ 2>/dev/null || true",
    "setup": "bash .devcontainer/scripts/setup-flutter.sh || echo 'Setup script not found'"
  },
  "postAttachCommand": "echo 'Connected to Flutter development environment'",

  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "ms-azuretools.vscode-docker",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "anthropic.claude-code",
        "openai.chatgpt",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "Google.geminicodeassist",
        "google.gemini-cli-vscode-ide-companion",
        "vadbeg.vsclaude",
        "d3j.gemini-cli-on-vscode",
        "continue.continue",
        "eamodio.gitlens",
        "k--kato.docomment",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter",
        "dart.debugExternalLibraries": true,
        "dart.debugSdkLibraries": false,
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll": true
        },
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh",
            "args": ["-l"]
          },
          "Codex": {
            "path": "/bin/zsh",
            "args": ["-c", "codex cmd; exec zsh"]
          },
          "Claude Code": {
            "path": "/bin/zsh",
            "args": ["-c", "claude cmd; exec zsh"]
          }
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
